# Frontend environment variables

NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com/ws
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_CREATOR_API_URL=https://api.example.com

# Creator auth routes (used by Clerk pages and creator UI links)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/creators/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/creators/signup
NEXT_PUBLIC_CREATOR_HOME_PATH=/creators
NEXT_PUBLIC_CREATOR_DASHBOARD_PATH=/creators/dashboard

# Clerk keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Server-side keys (do not expose in browser)
SUPABASE_SERVICE_KEY=your_supabase_service_key
JWT_SECRET=replace_with_strong_random_secret
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require
ADMIN_API_KEY=replace_with_admin_api_key
WEBHOOK_SECRET=replace_with_webhook_secret
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_ACCOUNT_NUMBER=replace_with_razorpay_account_number
