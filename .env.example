# ─────────────────────────────────────────────
# epocheye_website — environment variable template
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Clerk (creator auth) ──────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/creators/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/creators/signup
NEXT_PUBLIC_CREATOR_HOME_PATH=/creators
NEXT_PUBLIC_CREATOR_DASHBOARD_PATH=/creators/dashboard

# ── Neon (creator program DB) ─────────────────
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# ── JWT (website sessions, NOT Clerk) ─────────
JWT_SECRET=replace_with_strong_random_secret

# ── Razorpay ──────────────────────────────────
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret

# ── Admin dashboard (NOT Clerk) ───────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=replace_with_strong_random_secret
# Used by POST /api/admin/auth/seed to create the first admin user
ADMIN_SEED_KEY=replace_with_seed_key
# Legacy header-based key (kept for backward-compat tooling)
ADMIN_API_KEY=replace_with_admin_api_key

# ── Gemini (heritage embeddings) ──────────────
# Used by POST /api/admin/knowledge/embed to generate text-embedding-004 vectors.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Heritage knowledge DB (Neon, shared with Go backend) ──
# Same connection string as NEON_DB_URL in epocheye_backend.
HERITAGE_DB_URL=postgresql://username:password@host/dbname?sslmode=require

# ── Backend integration ───────────────────────
# The Go backend's Lambda API Gateway URL (same as epocheye_backend BACKEND_URL)
BACKEND_API_URL=https://zzlnrqm51d.execute-api.ap-south-1.amazonaws.com
# MUST match CREATOR_JWT_SECRET in epocheye_backend/.env exactly
CREATOR_JWT_SECRET=replace_with_shared_creator_jwt_secret
# MUST match WEBSITE_WEBHOOK_SECRET in epocheye_backend/.env exactly
WEBHOOK_SECRET=replace_with_shared_webhook_secret
